{
  "name": "opsclaw",
  "private": true,
  "version": "0.2.0",
  "description": "AI-native SSH operations workbench with Electron desktop packaging.",
  "author": "OpsClaw Contributors",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build",
    "desktop:build:electron": "tsc -p tsconfig.electron.json",
    "desktop:build": "pnpm build && pnpm desktop:build:electron",
    "desktop:dev": "pnpm desktop:build:electron && concurrently -k \"pnpm dev:client\" \"pnpm desktop:dev:app\"",
    "desktop:dev:app": "wait-on tcp:5173 && OPSCLAW_ELECTRON_RENDERER_URL=http://localhost:5173 electron dist-electron/electron/main.js",
    "desktop:pack": "pnpm desktop:build && electron-builder --config electron-builder.yml",
    "desktop:pack:win": "pnpm desktop:build && electron-builder --config electron-builder.yml --win dir zip --x64 -c.npmRebuild=false",
    "preview": "vite preview",
    "start:server": "node dist-server/server/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.62.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/sql.js": "^1.4.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "lucide-react": "^1.6.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "ssh2": "^1.16.0",
    "tailwind-merge": "^3.3.1",
    "ws": "^8.18.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@tailwindcss/vite": "^4.1.13",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "concurrently": "^9.1.2",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "wait-on": "^9.0.4"
  },
  "packageManager": "pnpm@8.12.1"
}
